{
  "name": "jarvis",
  "version": "0.0.1",
  "description": "Jarvis - Personal AI Assistant",
  "main": "dist-electron/main/index.js",
  "homepage": "./",
  "author": "TPACT",
  "license": "MIT",
  "scripts": {
    "predev": "npx vite build --config vite.backend.config.ts",
    "dev": "electron-vite dev",
    "build": "electron-vite build && npx vite build --config vite.backend.config.ts",
    "build:backend": "npx vite build --config vite.backend.config.ts",
    "preview": "electron-vite preview",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run",
    "test:watch": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs",
    "test:ui": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs --ui",
    "rebuild:native": "npm rebuild better-sqlite3 --runtime=electron --target=28.3.3 --disturl=https://electronjs.org/headers",
    "pack": "electron-builder",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@anthropic-ai/sdk": "^0.104.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^1.0.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.0",
    "vitest": "^0.34.0"
  }
}
