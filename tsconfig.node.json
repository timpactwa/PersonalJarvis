{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "noEmit": false
  },
  "include": ["electron.vite.config.ts", "src/main/**/*", "src/preload/**/*", "src/backend/**/*"]
}
